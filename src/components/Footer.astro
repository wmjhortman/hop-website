---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-20">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <div class="max-w-sm">
        <p class="font-heading text-lg font-medium mb-2">Human on Purpose</p>
        <p class="text-text-secondary text-sm leading-relaxed">
          Helping people be fully human - on purpose. Thoughtful essays, honest conversations, and a framework for living with meaning.
        </p>
      </div>

      <div class="flex gap-16">
        <div>
          <p class="text-xs uppercase tracking-widest text-text-secondary mb-3">Explore</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="text-text-secondary hover:text-accent">About</a></li>
            <li><a href="/listen" class="text-text-secondary hover:text-accent">Listen</a></li>
            <li><a href="/read" class="text-text-secondary hover:text-accent">Read</a></li>
            <li><a href="/books" class="text-text-secondary hover:text-accent">Books</a></li>
          </ul>
        </div>

        <div>
          <p class="text-xs uppercase tracking-widest text-text-secondary mb-3">Connect</p>
          <ul class="space-y-2 text-sm">
            <li><a href="https://humanonpurposeproject.substack.com" target="_blank" rel="noopener" class="text-text-secondary hover:text-accent">Substack</a></li>
            <li><a href="https://x.com/human_onpurpose" target="_blank" rel="noopener" class="text-text-secondary hover:text-accent">X / Twitter</a></li>
            <li><a href="https://instagram.com/human_onpurpose" target="_blank" rel="noopener" class="text-text-secondary hover:text-accent">Instagram</a></li>
            <li><a href="https://youtube.com/@HumanOnPurpose" target="_blank" rel="noopener" class="text-text-secondary hover:text-accent">YouTube</a></li>
          </ul>
        </div>
      </div>

    </div>

    <div class="mt-10 pt-6 border-t border-border text-center">
      <p class="text-xs text-text-secondary">&copy; {year} Human on Purpose. All rights reserved.</p>
    </div>
  </div>
</footer>
