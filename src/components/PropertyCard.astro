---
interface Props {
  title: string;
  description: string;
  href: string;
  linkText?: string;
  external?: boolean;
}

const { title, description, href, linkText = "Explore", external = false } = Astro.props;
---

<a
  href={href}
  class="group block p-6 border border-border rounded-lg hover:border-accent/40 hover:bg-accent-light/30 transition-all duration-200"
  {...external ? { target: "_blank", rel: "noopener" } : {}}
>
  <h3 class="font-heading text-lg font-medium mb-2 group-hover:text-accent transition-colors">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed mb-4">{description}</p>
  <span class="text-accent text-sm font-medium inline-flex items-center gap-1">
    {linkText}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-0.5 transition-transform">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </span>
</a>
